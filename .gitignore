# AI Framework - Minimal .gitignore
# Only framework-specific rules. Add your project rules below.

/.claude/*
!/.claude/rules/
/.claude/rules/.manifest-checksums
/CLAUDE.md
/hooks/*.db
/hooks/__pycache__/

# Ralph orchestrator (operational, per-objective)
/.ralph/

# Deep research artifacts (per-investigation)
/.research/

# Brainstorming session files (mockups, server state)
/.brainstorm/

# Visual companion session files (frontend-design mockups)
/.visual-companion/

# Specs and planning artifacts (remove to track in git)
/docs/specs/

# Next.js
/.next/
/out/
/build

# Dependencies
/node_modules/

# Environment variables
.env.local
.env*.local

# SQLite database (local only)
local.db
*.db

# Misc
.DS_Store
*.pem
/coverage

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# SQLite WAL/SHM artifacts
local.db-shm
local.db-wal
seed-test.db*
